# ============================================
# Storylab.io — Configurazione
# ============================================
# Copia questo file in .env e inserisci i tuoi valori reali:
#   cp .env.example .env

# Gemini API (text + image generation)
GEMINI_API_KEY=your_gemini_api_key

# Black Forest Labs — FLUX.1 (opzionale, non piu' usato)
BFL_API_KEY=your_bfl_api_key

# Meta / Facebook Graph API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Theme (crescita_personale, enoteca, fitness, ristorante)
THEME=crescita_personale

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./storylab.db
